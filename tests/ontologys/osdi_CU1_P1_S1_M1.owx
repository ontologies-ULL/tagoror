</DataPropertyAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasExpectedValue"/>
<NamedIndividual IRI="#BTD_Screening_Sensitivity"/>
<Literal>0.99</Literal>
</DataPropertyAssertion>

