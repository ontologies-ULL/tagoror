<NamedIndividual IRI="#BTD_Intervention_Screening"/>
<Literal>Cribado neonatal de la deficiencia de biotinidasa mediante ensayo enzimático o fluorimétrico semicuantitativo</Literal>
</DataPropertyAssertion>

