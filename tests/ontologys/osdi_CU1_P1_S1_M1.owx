</DataPropertyAssertion>

<!-- Parámetros epidemiológicos -->
<Declaration>
<NamedIndividual IRI="#BTD_Incidence"/>
</Declaration>

<ClassAssertion>
<Class IRI="#EpidemiologicalParameter"/>
<NamedIndividual IRI="#BTD_Incidence"/>
</ClassAssertion>

<ClassAssertion>
<Class IRI="#SecondOrderUncertaintyParameter"/>
<NamedIndividual IRI="#BTD_Incidence"/>
</ClassAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasDescription"/>
<NamedIndividual IRI="#BTD_Incidence"/>
<Literal>Incidencia de la deficiencia profunda de biotinidasa</Literal>
</DataPropertyAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasExpectedValue"/>
<NamedIndividual IRI="#BTD_Incidence"/>
<Literal>0.0000125</Literal>
</DataPropertyAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasSource"/>
<NamedIndividual IRI="#BTD_Incidence"/>
<Literal>Wolf B. Worldwide survey of neonatal screening for biotinidase deficiency. J Inherit Metab Dis 1991;14:923-927</Literal>
</DataPropertyAssertion>

<Declaration>
<NamedIndividual IRI="#BTD_Screening_Sensitivity"/>
</Declaration>

