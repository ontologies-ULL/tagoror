    <!-- Definición de la enfermedad principal -->
<Declaration>
<NamedIndividual IRI="#BTD_Disease"/>
</Declaration>

<ClassAssertion>
<Class IRI="#Disease"/>
<NamedIndividual IRI="#BTD_Disease"/>
</ClassAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasDescription"/>
<NamedIndividual IRI="#BTD_Disease"/>
<Literal>Deficiencia de biotinidasa</Literal>
</DataPropertyAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasSource"/>
<NamedIndividual IRI="#BTD_Disease"/>
<Literal>Wolf B. Disorders of biotin metabolism. In: Scriver CR et al., eds. The metabolic and molecular bases of inherited disease, 7th ed. 2001</Literal>
</DataPropertyAssertion>

<!-- Clasificaciones de la enfermedad -->
<Declaration>
<NamedIndividual IRI="#BTD_Disease_Profound"/>
</Declaration>

<ClassAssertion>
<Class IRI="#Disease"/>
<NamedIndividual IRI="#BTD_Disease_Profound"/>
</ClassAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasDescription"/>
<NamedIndividual IRI="#BTD_Disease_Profound"/>
<Literal>Deficiencia profunda de biotinidasa (actividad enzimática menor del 10% del valor normal)</Literal>
</DataPropertyAssertion>

<Declaration>
<NamedIndividual IRI="#BTD_Disease_Partial"/>
</Declaration>

<ClassAssertion>
<Class IRI="#Disease"/>
<NamedIndividual IRI="#BTD_Disease_Partial"/>
</ClassAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasDescription"/>
<NamedIndividual IRI="#BTD_Disease_Partial"/>
<Literal>Deficiencia parcial de biotinidasa (actividad enzimática 10-30% del valor normal)</Literal>
</DataPropertyAssertion>

<!-- Relaciones entre las clasificaciones y la enfermedad principal -->
<ObjectPropertyAssertion>
<ObjectProperty IRI="#isSubtypeOf"/>
<NamedIndividual IRI="#BTD_Disease_Profound"/>
<NamedIndividual IRI="#BTD_Disease"/>
</ObjectPropertyAssertion>

<ObjectPropertyAssertion>
<ObjectProperty IRI="#isSubtypeOf"/>
<NamedIndividual IRI="#BTD_Disease_Partial"/>
<NamedIndividual IRI="#BTD_Disease"/>
</ObjectPropertyAssertion>

