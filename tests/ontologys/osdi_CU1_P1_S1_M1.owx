</ClassAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasDescription"/>
<NamedIndividual IRI="#BTD_Screening_Specificity"/>
<Literal>Especificidad del cribado neonatal para la deficiencia de biotinidasa</Literal>
</DataPropertyAssertion>

<DataPropertyAssertion>
<DataProperty IRI="#hasExpectedValue"/>
<NamedIndividual IRI="#BTD_Screening_Specificity"/>
