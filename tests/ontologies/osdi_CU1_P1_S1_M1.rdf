                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLifeExpectancyReduction"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasOnsetAge"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityOfDeath"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
