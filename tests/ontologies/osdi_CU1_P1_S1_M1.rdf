        <hasTreatmentCost rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_BiotinTreatment_AnnualCost"/>
        <hasDescription>Tratamiento con biotina oral (5-30 mg/día)</hasDescription>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_ClinicalDiagnosis -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_ClinicalDiagnosis">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
        <hasDescription>Detección clínica de la deficiencia de biotinidasa tras aparición de síntomas</hasDescription>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_Screening -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_Screening">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
        <modifies rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_HearingLoss_Prob_WithoutTreatment"/>
        <hasDescription>Cribado neonatal de la deficiencia de biotinidasa mediante ensayo enzimático o fluorimétrico semicuantitativo</hasDescription>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_Combined_U -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_Combined_U">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#UtilityParameter"/>
        <appliesOneTime>false</appliesOneTime>
        <hasDescription>Desutilidad anual para casos graves con múltiples síntomas</hasDescription>
        <hasExpectedValue>0.49</hasExpectedValue>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay">
