    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#followedByStrategy"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                                <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasConditionExpression"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ConditionExpression"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProportionWithinGroup"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasUtility"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#TherapeuticIntervention -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#TherapeuticIntervention">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFollowUpStrategy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLineOfTherapy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Treatment -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Treatment">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Any non-drug intervention used to treat a disease or manifestation</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#UniformDistributionExpression -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#UniformDistributionExpression">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLowerLimitParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasUpperLimitParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#appliesOneTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCalculationMethod"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#UtilityParameter -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#UtilityParameter"/>
    


