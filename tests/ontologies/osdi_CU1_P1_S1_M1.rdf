    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay_Prob_LateTraeatment -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay_Prob_LateTraeatment">
