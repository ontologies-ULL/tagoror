    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_OpticAtrophy -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_OpticAtrophy">
