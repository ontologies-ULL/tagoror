                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Certain progression of a Disease that comprises a specific set of manifestations or a set of pathways to such manifestations</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#DevelopmentPathway -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DevelopmentPathway">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Pathway"/>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisIntervention -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisIntervention">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionIntervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDiagnosisStrategy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ScreeningIntervention"/>
        <rdfs:comment>An intervention intended to establish the presence/absence of certain disease or condition</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionStrategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiscreteEventSimulationModel -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiscreteEventSimulationModel">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
    </owl:Class>
    


