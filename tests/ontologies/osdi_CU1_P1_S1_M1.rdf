                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment xml:lang="en">The initial proportion of patients of a population that already present certain manifestation</rdfs:comment>
    </owl:ObjectProperty>
    


