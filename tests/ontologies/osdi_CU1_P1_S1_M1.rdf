    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_OpticAtrophy_Prob_LateTraeatment -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_OpticAtrophy_Prob_LateTraeatment">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
