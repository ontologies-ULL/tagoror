    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSensitivity -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSensitivity">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionIntervention"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment>The Sensitivity in epidemiology is the Probability of correctly classifying a sick individual, that is, the Probability that a positive result will be obtained in a diagnostic test for a sick subject. The Sensitivity is, therefore, the ability of the complementary test to detect the disease. Sensitivity is the percentage of true positives or the Probability that the test is positive if the disease is present; False negatives are sick subjects diagnosed as healthy.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSex -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSex">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAttributeValue"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isValueOfAttribute"/>
                <owl:hasValue rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Sex"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSpecificity -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasSpecificity">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionIntervention"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment>Start Age</rdfs:comment>
        <rdfs:comment>The Specificity of a test is the Probability that a healthy subject will have a negative test result. Specificity is the percentage of true negatives or the Probability that the test will be negative if the disease is not present. False positives are healthy subjects diagnosed as sick.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasStage -->

