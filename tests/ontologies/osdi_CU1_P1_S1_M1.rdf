        <hasExpectedValue>0.55</hasExpectedValue>
        <hasExpectedValue>0.75</hasExpectedValue>
        <hasSource>Wolf B et al. Hearing loss is a common feature... J Pediatr 2002;140:242-246</hasSource>
        <hasSource>Wolf B, Spencer R, Gleason T. Hearing loss is a common feature of symptomatic children with profound biotinidase deficiency. J Pediatr 2002;140:242-246</hasSource>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_HearingLoss_U -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_HearingLoss_U">
