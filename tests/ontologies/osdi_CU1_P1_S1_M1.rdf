    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRange -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRange">
        <rdfs:comment>Age range in which the drug will be delivered.

Examples: 
   0y-2y    =&gt; 0 years to 2 years
   3m-2y   =&gt; 3 months to 2 years</rdfs:comment>
    </owl:DatatypeProperty>
    


