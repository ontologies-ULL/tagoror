    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasName">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DataItemType"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasOffsetParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasOffsetParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityParameter -->

