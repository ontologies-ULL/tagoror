    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#RareDisease -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#RareDisease">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <rdfs:subClassOf>
            <owl:Restriction>
