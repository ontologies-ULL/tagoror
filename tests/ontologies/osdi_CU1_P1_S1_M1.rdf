        <hasDescription>Probabilidad de desarrollar retraso del desarrollo sin tratamiento</hasDescription>
        <hasExpectedValue>0.60</hasExpectedValue>
        <hasSource>Moslinger D et al. Clinical and neuropsychological outcome in 33 patients with biotinidase deficiency ascertained by nationwide newborn screening and family studies in Austria. Eur J Pediatr 2001;160:277-282</hasSource>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay_U -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay_U">
