    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#AdditiveDisutility -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#AdditiveDisutility"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Age -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Age">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
        <hasDescription>The age of an individual (in years)</hasDescription>
        <hasName>AGE</hasName>
        <hasRefToSNOMED>snomed:397669002</hasRefToSNOMED>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_LifeExpectancy -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_LifeExpectancy">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
        <hasDescription>Maximum life expectacy of an individual</hasDescription>
        <hasName>LIFE_EXPECTANCY</hasName>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Sex -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Sex">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
        <hasDescription>Sex (0 for male; 1 for female)</hasDescription>
        <hasName>SEX</hasName>
        <hasRefToSNOMED>snomed:734000001</hasRefToSNOMED>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_BiotinTreatment_AnnualCost -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_BiotinTreatment_AnnualCost">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CostParameter"/>
        <hasDescription>Coste anual del tratamiento con biotina (5-10 mg/día)</hasDescription>
        <hasExpectedValue>730</hasExpectedValue>
        <hasUnit>EUR</hasUnit>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_DiagnosticTest_Cost -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_DiagnosticTest_Cost">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CostParameter"/>
        <hasDescription>Coste de la prueba diagnóstica confirmatoria</hasDescription>
        <hasExpectedValue>150</hasExpectedValue>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#RareDisease"/>
        <hasDisutilityCombinationMethod rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#AdditiveDisutility"/>
        <hasEpidemiologicalParameter rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Incidence"/>
        <hasFollowUpStrategy rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_FollowUp_AnnualMonitoring"/>
        <hasDescription>Deficiencia de biotinidasa</hasDescription>
        <hasSource>Wolf B. Disorders of biotin metabolism. In: Scriver CR et al., eds. The metabolic and molecular bases of inherited disease, 7th ed. 2001</hasSource>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease_Partial -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease_Partial">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <isSubtypeOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease"/>
        <hasDescription>Deficiencia parcial de biotinidasa (actividad enzimática 10-30% del valor normal)</hasDescription>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease_Profound -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease_Profound">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_DevelopmentalDelay"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_HearingLoss"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_Hypotonia"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_OpticAtrophy"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_Seizures"/>
        <hasFeature rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Manif_SkinProblems"/>
        <isSubtypeOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Disease"/>
        <hasDescription>Deficiencia profunda de biotinidasa (actividad enzimática menor del 10% del valor normal)</hasDescription>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_FollowUp_AnnualMonitoring -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_FollowUp_AnnualMonitoring">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Incidence -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Incidence">
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#EpidemiologicalParameter"/>
        <rdf:type rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#SecondOrderUncertaintyParameter"/>
        <hasDescription>Incidencia de la deficiencia profunda de biotinidasa</hasDescription>
        <hasExpectedValue>0.0000125</hasExpectedValue>
        <hasSource>Wolf B. Worldwide survey of neonatal screening for biotinidase deficiency. J Inherit Metab Dis 1991;14:923-927</hasSource>
    </owl:NamedIndividual>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_BiotinTreatment -->

    <owl:NamedIndividual rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BTD_Intervention_BiotinTreatment">
