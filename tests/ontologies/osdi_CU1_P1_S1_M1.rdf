            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgressionPathway -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgressionPathway">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Pathway"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#requires"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#requires"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgression"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#requires"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The way a manifestation appears. It may be a probability, time to event, a proportion of people affected..., and it may change depending on the Development of the Disease or a specific Intervention</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Drug -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Drug">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology"/>
