        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#isSubpopulationOf -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isSubpopulationOf">
