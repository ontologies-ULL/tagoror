            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A natural or synthetic remedy for a disease or manifestation</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#EpidemiologicalParameter -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#EpidemiologicalParameter">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isTrueEpidemiologicalParameterEstimate"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExponentialDistributionExpression -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExponentialDistributionExpression">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLambdaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExpressionLanguage -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExpressionLanguage">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Exp_Excel"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Exp_JEXL"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Exp_Java"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Exp_Javaluator"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#FirstOrderUncertaintyParameter -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FirstOrderUncertaintyParameter">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ParameterNature"/>
