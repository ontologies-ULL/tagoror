                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
                <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpTest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpTest -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpTest">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Tests performed to monitor the state of a patient</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#GammaDistributionExpression -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GammaDistributionExpression">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAlfaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLambdaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasConditionExpression"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ConditionExpression"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDose"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFrequency"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRange"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasHoursInterval"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The way a treatment, drug, test... is applied. It defines a period of time (range), dose, frequency, etc.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProportionWithinGroup"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Any treatment, drug, test... that may be applied to a patient</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasUtility"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#involvesModification"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#modifies"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Some kind of treatment, drug, surgical procedure... used to modify the development of a Disease</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Drug"/>
                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Treatment"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#failsIf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgression"/>
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#excludesManifestation"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Symptoms and signs of a Disease. They may be chronic or acute</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#MarkovModel -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#MarkovModel">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#MeasuredDataItemType -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#MeasuredDataItemType">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DataItemType"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasUnit"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesSameModelItemsAs"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAuthor"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGeographicalContext"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRefTo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasYear"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDisutilityCombinationMethod"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange>
                    <rdfs:Datatype>
                        <owl:oneOf>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>ADD</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>MAX</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </owl:oneOf>
                    </rdfs:Datatype>
                </owl:onDataRange>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#includedByModel"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#NormalDistributionExpression -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#NormalDistributionExpression">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
    </owl:Class>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter -->

    <owl:Class rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter">
        <rdfs:subClassOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isModifiedBy"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isParameterOfDisease"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isParameterOfManifestation"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isParameterOfPopulation"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#modifies"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDataItemType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DataItemType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isValueOfAttribute"/>
