    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#isValueOfAttribute -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isValueOfAttribute">
