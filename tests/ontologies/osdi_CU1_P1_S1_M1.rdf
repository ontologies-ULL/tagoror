                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityOfDiagnosis"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRiskCharacterization"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
                            <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Pathway"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasUtility"/>
                <owl:someValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasRefToICD"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
