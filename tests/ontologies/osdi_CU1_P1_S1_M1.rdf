        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#modifies -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#modifies">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#requires -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#requires">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgressionPathway"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Stage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesDrug -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesDrug">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Drug"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesFollowUpTest -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesFollowUpTest">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpTest"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesSameModelItemsAs -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesSameModelItemsAs">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
        <rdfs:comment>Defines that a model uses the same data items as another model. Useful for avoiding &quot;recreating&quot; that relationship for all the model items in models which are very similar and simply difer in some characteristics.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesTreatment -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesTreatment">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#usesHealthTechnology"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Treatment"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#REMOVEhasFrequency -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#REMOVEhasFrequency">
        <rdfs:comment>Indicates the time cycle of how often the treatment, the follow-up test or their respective strategies have to be applied. In the case of a manifestation of the disease, it will indicate how many times a year the symptom manifests itself. 

By default = 1, for the Manifestations.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#appliesOneTime -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#appliesOneTime">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Defines the temporal behavior of a parameter (generally a cost or utility): if true, applies upon onset of some model item (disease, disease progression...); otherwise, it is assumed to apply annually.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#failsIf -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#failsIf"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAlfaParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAlfaParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BetaDistributionExpression"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAuthor -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAuthor">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAverageParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAverageParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProbabilityDistributionExpression"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasBetaParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasBetaParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#BetaDistributionExpression"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCalculationMethod -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCalculationMethod">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Utility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDescription">
        <rdfs:comment>Description of the cost</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDisutilityCombinationMethod -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDisutilityCombinationMethod">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>ADD</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>MAX</rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpectedValue -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpectedValue">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpressionValue -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpressionValue">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CalculatedParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGeographicalContext -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGeographicalContext">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Model"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasHoursInterval -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasHoursInterval">
        <rdfs:comment>Interval in which the indicated dose of drug should be given.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLambdaParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLambdaParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExponentialDistributionExpression"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#PoissonDistributionExpression"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLowerLimitParameter -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasLowerLimitParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#UniformDistributionExpression"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasMaxAge -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasMaxAge">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasMinAge -->

    <owl:DatatypeProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasMinAge">
