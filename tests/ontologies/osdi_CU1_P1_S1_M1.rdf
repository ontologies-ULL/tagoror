<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ull.es/iis/simulation/ontologies/disease-simulation#"
     xml:base="http://www.ull.es/iis/simulation/ontologies/disease-simulation"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:opla-sd="http://ontologydesignpatterns.org/opla-sd#"
     xmlns:ontodebug="http://ainf.aau.at/ontodebug#">
    <owl:Ontology rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation">
        <owl:versionIRI rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation/1.0"/>
        <contributor>María Luz Couce Pico (https://orcid.org/0000-0003-4861-9905)</contributor>
        <creator>David Prieto González (https://orcid.org/0000-0003-1411-129X)</creator>
        <creator>Evelio J. González González (https://orcid.org/0000-0002-2203-3757)</creator>
        <creator>Iván Castilla Rodríguez (http://orcid.org/0000-0003-3933-2582)</creator>
        <rdfs:comment xml:lang="en">Ontology designed for collecting and inferring the parameters required to create a simulation-based Health Technology Assesment</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ainf.aau.at/ontodebug#testCase -->

    <owl:AnnotationProperty rdf:about="http://ainf.aau.at/ontodebug#testCase"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPosition -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPosition"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPositionX -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPositionX"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPositionY -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPositionY"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#TODO -->

    <owl:AnnotationProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#TODO"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#contributor -->

    <owl:AnnotationProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#contributor"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#creator -->

    <owl:AnnotationProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#creator"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#belongsToGroup">
        <owl:inverseOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ProportionWithinGroup"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#dependsOnAttribute -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#dependsOnAttribute">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CalculatedParameter"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a Valuable instance and an Attribute, where the &quot;hasExpression&quot; of the domain instance makes reference to the range instance. Hence, the hasExpression property should include a reference to that attribute, so that the final value of this Valuable is a function of the value of this attribute.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#dependsOnParameter -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#dependsOnParameter">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CalculatedParameter"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a Valuable instance and a Parameter, where the &quot;hasExpression&quot; of the domain instance makes reference to the range instance. Hence, the hasExpression property should include a reference to that parameter, so that the final value of this Valuable is a function of the value of this parameter.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#excludesManifestation -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#excludesManifestation">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#followedByStrategy -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#followedByStrategy">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAge -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAge">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAttributeValue"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#isValueOfAttribute"/>
                <owl:hasValue rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Attribute_Age"/>
            </owl:Restriction>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAttributeValue -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasAttributeValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Group"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#GroupableModelItem"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasConditionExpression -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasConditionExpression">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Pathway"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ConditionExpression"/>
        <rdfs:comment xml:lang="en">It allows expressing conditions based on parameters that we will find in the model. For example, we can find that certain drugs will be administered depending on the weight or age of the patient.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#HealthTechnology"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Intervention"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Stage"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDataItemType -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDataItemType">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DataItemType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDevelopment -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDevelopment">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDiagnosisCost -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDiagnosisCost">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDiagnosisStrategy -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDiagnosisStrategy">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasStrategy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisIntervention"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ScreeningStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiagnosisStrategy"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDose -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDose">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment xml:lang="en">Dosage of the indicated drug</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDuration -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasDuration">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#DiseaseProgression"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasEndAge -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasEndAge">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasEpidemiologicalParameter -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasEpidemiologicalParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#EpidemiologicalParameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpressionLanguage -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasExpressionLanguage">
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#CalculatedParameter"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ExpressionLanguage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFeature -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFeature"/>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFollowUpCost -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFollowUpCost">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasCost"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Cost"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFollowUpStrategy -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFollowUpStrategy">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasStrategy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Development"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Disease"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#TherapeuticIntervention"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasComponent"/>
                        <owl:allValuesFrom rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFrequency -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasFrequency">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#AcuteManifestation"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment xml:lang="en">Indicates the time cycle of how often the treatment, the follow-up test or their respective strategies have to be applied. In the case of a manifestation of the disease, it will indicate how many times a year the symptom manifests itself. 

By default = 1, for the Manifestations.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasGuideline">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Drug"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpStrategy"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#FollowUpTest"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#LineOfTherapy"/>
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Treatment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Guideline"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasIncreasedMortalityRate -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasIncreasedMortalityRate">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Manifestation"/>
        <rdfs:range rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Parameter"/>
        <rdfs:comment>By default = 1</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasInitialProportion -->

    <owl:ObjectProperty rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasInitialProportion">
        <rdfs:subPropertyOf rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#hasParameter"/>
        <rdfs:domain rdf:resource="http://www.ull.es/iis/simulation/ontologies/disease-simulation#Population"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ull.es/iis/simulation/ontologies/disease-simulation#ChronicManifestation"/>
