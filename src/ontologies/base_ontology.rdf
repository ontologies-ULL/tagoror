                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a parameter and a clinical progression element, disease, intervention, pathway, population or resource usage item, indicating that the parameter is associated with that element.</rdfs:comment>
        <rdfs:label xml:lang="es">es parámetro de</rdfs:label>
        <rdfs:label xml:lang="en">is parameter of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isProgressionElementOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isProgressionElementOf">
