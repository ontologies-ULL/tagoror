                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a detection strategy or intervention and a disease, indicating that such estrategy or intervention is used to identify the disease.</rdfs:comment>
        <rdfs:label xml:lang="es">es detectado por</rdfs:label>
        <rdfs:label xml:lang="en">is detected by</rdfs:label>
    </owl:ObjectProperty>
    


