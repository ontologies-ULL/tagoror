<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/ontologies-ULL/OSDi#"
     xml:base="https://w3id.org/ontologies-ULL/OSDi"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:osdi="https://w3id.org/ontologies-ULL/OSDi#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:opla-sd="http://ontologydesignpatterns.org/opla-sd#"
     xmlns:ontodebug="http://ainf.aau.at/ontodebug#">
    <owl:Ontology rdf:about="https://w3id.org/ontologies-ULL/OSDi">
        <owl:versionIRI rdf:resource="https://w3id.org/ontologies-ULL/OSDi/1.1"/>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by-nc-sa/4.0/"/>
        <dc:contributor>María Luz Couce Pico (https://orcid.org/0000-0003-4861-9905)</dc:contributor>
        <dc:creator>David Prieto González (https://orcid.org/0000-0003-1411-129X)</dc:creator>
        <dc:creator>Evelio J. González González (https://orcid.org/0000-0002-2203-3757)</dc:creator>
        <dc:creator>Iván Castilla Rodríguez (http://orcid.org/0000-0003-3933-2582)</dc:creator>
        <dc:description xml:lang="en">Ontology designed for collecting and inferring the parameters required to create a simulation-based Health Technology Assesment</dc:description>
        <dc:description xml:lang="es">Ontología diseñada para recopilar e inferir los parámetros necesarios para crear una evaluación de tecnología sanitaria basada en simulación</dc:description>
        <dc:source rdf:resource="https://github.com/ontologies-ULL/OSDi"/>
        <dcterms:abstract xml:lang="en">This ontology provides a structured framework for the interoperability of health economics data used to create models. The ontology represents all the concepts and relationships involved in health technology assessment, including the characterization of the disease and its development, the population affected, and the interventions applied.</dcterms:abstract>
        <rdfs:label xml:lang="en">OSDi</rdfs:label>
        <rdfs:label xml:lang="es">OSDi</rdfs:label>
        <owl:versionInfo>1.1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ainf.aau.at/ontodebug#testCase -->

    <owl:AnnotationProperty rdf:about="http://ainf.aau.at/ontodebug#testCase"/>
    


    <!-- http://creativecommons.org/ns#license -->

    <owl:AnnotationProperty rdf:about="http://creativecommons.org/ns#license"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPosition -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPosition"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPositionX -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPositionX"/>
    


    <!-- http://ontologydesignpatterns.org/opla-sd#entityPositionY -->

    <owl:AnnotationProperty rdf:about="http://ontologydesignpatterns.org/opla-sd#entityPositionY"/>
    


    <!-- http://purl.org/dc/elements/1.1/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributor"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/source"/>
    


    <!-- http://purl.org/dc/terms/abstract -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#TODO -->

    <owl:AnnotationProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#TODO"/>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#contributor -->

    <owl:AnnotationProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#contributor"/>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#creator -->

    <owl:AnnotationProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#creator"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf"/>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#affects -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#affects">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isAffectedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between an effect and an attribute or parameter, indicating that the effect affects the attribute or parameter.</rdfs:comment>
        <rdfs:label xml:lang="es">afecta</rdfs:label>
        <rdfs:label xml:lang="en">affects</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#affectsProgressionElement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#affectsProgressionElement">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines the combination rule that affects certain progression element</rdfs:comment>
        <rdfs:label xml:lang="es">afecta al elemento de progresión</rdfs:label>
        <rdfs:label xml:lang="en">affects progression element</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#belongsToGroup -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#belongsToGroup">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGroupItem"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Group"/>
        <rdfs:comment xml:lang="en">Indicates that a model item belongs to a group, which can be used to define the strategies that are applied to a health condition, intervention or strategy, as well as the strategies that are part of a group of strategies.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to group</rdfs:label>
        <rdfs:label xml:lang="es">pertenece al grupo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#causesFailOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#causesFailOf">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#failsIf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
        <rdfs:comment xml:lang="en">Defines the condition (expressed as any type of parameter) upon which certain strategy fails and must progress to the next step</rdfs:comment>
        <rdfs:label xml:lang="es">causa el fallo de</rdfs:label>
        <rdfs:label xml:lang="en">causes fail of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#dependsOn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#dependsOn">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDependantCalculatedParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a Valuable instance and an Attribute, where the &quot;hasExpression&quot; of the domain instance makes reference to the range instance. Hence, the hasExpression property should include a reference to that attribute, so that the final value of this Valuable is a function of the value of this attribute.</rdfs:comment>
        <rdfs:label xml:lang="es">depende del atributo</rdfs:label>
        <rdfs:label xml:lang="en">depends on attribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#detects -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#detects">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isDetectedBy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:comment xml:lang="en">Indicates the disease detected by a detection intervention</rdfs:comment>
        <rdfs:label xml:lang="es">detecta</rdfs:label>
        <rdfs:label xml:lang="en">detects</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#failsIf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#failsIf">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the condition (expressed as any type of parameter) upon which certain strategy fails and must progress to the next step</rdfs:comment>
        <rdfs:label xml:lang="en">fails if</rdfs:label>
        <rdfs:label xml:lang="es">falla si</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#followedByStrategy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#followedByStrategy">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#followsStrategy"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:comment xml:lang="en">Defines the relationship between two strategies, where one is followed by the other.</rdfs:comment>
        <rdfs:label xml:lang="en">followed by strategy</rdfs:label>
        <rdfs:label xml:lang="es">seguido por la estrategia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#followsStrategy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#followsStrategy">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:comment xml:lang="en">Defines the relationship between two strategies, where one follows the other.</rdfs:comment>
        <rdfs:label xml:lang="en">follows strategy</rdfs:label>
        <rdfs:label xml:lang="es">sigue la estrategia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasAge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasAge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_Age"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines the age of the population, which can be used to define the characteristics of the disease and the interventions. The value is the average age of the individuals in the population.</rdfs:comment>
        <rdfs:label xml:lang="en">has age</rdfs:label>
        <rdfs:label xml:lang="es">tiene edad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasAttributeValue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasAttributeValue">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines a value for an attribute, which should be used by a population and/or disease</rdfs:comment>
        <rdfs:label xml:lang="en">has attribute value</rdfs:label>
        <rdfs:label xml:lang="es">tiene el valor del atributo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasCategory">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="es">Asocia un coste o una estrategia con un concepto SKOS usado con fines de clasificación y análisis.</rdfs:comment>
        <rdfs:comment xml:lang="en">Associates a cost or a strategy with a SKOS concept used for classification and analysis purposes.</rdfs:comment>
        <rdfs:label xml:lang="en">has category</rdfs:label>
        <rdfs:label xml:lang="es">tiene categoría</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasConditionExpression -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasConditionExpression">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isConditionExpressionOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">It allows expressing conditions based on parameters that we will find in the model. For example, we can find that certain drugs will be administered depending on the weight or age of the patient.</rdfs:comment>
        <rdfs:label xml:lang="en">has condition expression</rdfs:label>
        <rdfs:label xml:lang="es">tiene la expresión de condición</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasCost -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasCost">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
        <rdfs:comment xml:lang="en">Defines the cost of a health condition, health technology, intervention, pathway or strategy.</rdfs:comment>
        <rdfs:label xml:lang="en">has cost</rdfs:label>
        <rdfs:label xml:lang="es">tiene el coste</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDataItemType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isDataItemTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
        <rdfs:comment xml:lang="en">Defines the type of data item that represents the parameter, which can be used to determine how to use the parameter in the model and how to obtain its value.</rdfs:comment>
        <rdfs:label xml:lang="en">has data item type</rdfs:label>
        <rdfs:label xml:lang="es">tiene el tipo de datos</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDependantCalculatedParameter -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDependantCalculatedParameter">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
        <rdfs:comment xml:lang="en">Defines a calculated parameter that depends on other parameters.</rdfs:comment>
        <rdfs:label xml:lang="en">has dependant calculated parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro calculado dependiente</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDose -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDose">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the dosage of the indicated drug</rdfs:comment>
        <rdfs:label xml:lang="en">has dose</rdfs:label>
        <rdfs:label xml:lang="es">tiene la dosis</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDuration -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDuration">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the duration of a certain manifestation of the disease, or the duration of an intervention, etc. This value must be expressed in number of years.</rdfs:comment>
        <rdfs:label xml:lang="en">has duration</rdfs:label>
        <rdfs:label xml:lang="es">tiene la duración</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasEffect -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasEffect">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isEffectOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a health condition, intervention, pathway, population or resource usage item and an effect, indicating that the health condition, intervention, pathway, population or resource usage item has a certain effect on the disease progression or on the patients.</rdfs:comment>
        <rdfs:label xml:lang="en">has effect</rdfs:label>
        <rdfs:label xml:lang="es">tiene el efecto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasEffectMagnitude -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasEffectMagnitude">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the parameter that defines the magnitude of the effect</rdfs:comment>
        <rdfs:label xml:lang="en">has magnitude effect</rdfs:label>
        <rdfs:label xml:lang="es">tiene magnitud del efecto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasEndAge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasEndAge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the age at which a certain condition or disease ends.</rdfs:comment>
        <rdfs:label xml:lang="en">has end age</rdfs:label>
        <rdfs:label xml:lang="es">tiene la edad de finalización</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter"/>
        <rdfs:comment xml:lang="en">Defines an epidemiological parameter of a disease or a population, such as the incidence, prevalence, mortality, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">has epidemiological parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro epidemiológico</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasExpressionLanguage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasExpressionLanguage">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isExpressionLanguageOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage"/>
        <rdfs:comment xml:lang="en">Defines the expression language used in a calculated parameter, which can be any formal language that allows us to express mathematical formulas, such as MathML or OpenMath.</rdfs:comment>
        <rdfs:label xml:lang="en">has expression language</rdfs:label>
        <rdfs:label xml:lang="es">tiene el lenguage de expresión</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasFirst -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasFirst">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#SequentialCombinationRule"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
        <rdfs:comment xml:lang="en">Points to the first of a set of ordered items</rdfs:comment>
        <rdfs:label xml:lang="en">has first</rdfs:label>
        <rdfs:label xml:lang="es">tiene primero</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasFrequency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasFrequency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Indicates the time cycle of how often the treatment, the follow-up test or their respective strategies have to be applied. In the case of a manifestation of the disease, it will indicate how many times a year the symptom manifests itself.</rdfs:comment>
        <rdfs:label xml:lang="en">has frequency</rdfs:label>
        <rdfs:label xml:lang="es">tiene la frecuencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasGroupItem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasGroupItem">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Group"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem"/>
        <rdfs:comment xml:lang="en">Describes the items of a group</rdfs:comment>
        <rdfs:label xml:lang="en">has group item</rdfs:label>
        <rdfs:label xml:lang="es">tiene el elemento del grupo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasGuideline -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasGuideline">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isGuidelineOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a health technology or a strategy and a guideline, indicating that the guideline is applied to the health technology or strategy.</rdfs:comment>
        <rdfs:label xml:lang="en">has guideline</rdfs:label>
        <rdfs:label xml:lang="es">tiene la pauta</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Development"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Stage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the initial proportion of patients of a population that already present certain manifestation</rdfs:comment>
        <rdfs:label xml:lang="en">has initial proportion</rdfs:label>
        <rdfs:label xml:lang="es">tiene la proporción inicial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasIntervention -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasIntervention">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isInterventionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a disease and an intervention, indicating that the intervention is applied to the disease.</rdfs:comment>
        <rdfs:label xml:lang="en">has intervention</rdfs:label>
        <rdfs:label xml:lang="es">tiene la intervención</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasLifeExpectancy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasLifeExpectancy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the life expectancy of the population, which is the average number of years that an individual of the population is expected to live. This value must be expressed in number of years.</rdfs:comment>
        <rdfs:label xml:lang="en">has life expectancy</rdfs:label>
        <rdfs:label xml:lang="es">tiene la esperanza de vida</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasNext -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasNext">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasPrevious"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
        <rdfs:comment xml:lang="en">Points to the next ordered model item</rdfs:comment>
        <rdfs:label xml:lang="en">has next</rdfs:label>
        <rdfs:label xml:lang="es">tiene siguiente</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasOnsetAge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasOnsetAge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the age at which a certain manifestation of the disease appears. This value must be expressed in number of years.</rdfs:comment>
        <rdfs:label xml:lang="en">has onset age</rdfs:label>
        <rdfs:label xml:lang="es">tiene la edad de inicio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasParameter -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasParameter">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a disease, intervention, pathway, population or resource usage item and a parameter, indicating that the parameter is used to characterize the disease, intervention, pathway, population or resource usage item.</rdfs:comment>
        <rdfs:label xml:lang="en">has parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasPrevious -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasPrevious">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
        <rdfs:comment xml:lang="en">Points to the previous ordered model item</rdfs:comment>
        <rdfs:label xml:lang="en">has previous</rdfs:label>
        <rdfs:label xml:lang="es">tiene anterior</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isProgressionElementOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a disease and its progression element, indicating that an individual affected by the disease can have the progression element.</rdfs:comment>
        <rdfs:label xml:lang="en">has progression element</rdfs:label>
        <rdfs:label xml:lang="es">has progression element</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasProportionWithinGroup -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasProportionWithinGroup">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItemWithProportion"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines the proportion of patients that present a certain characteristic within a group. For example, the proportion of patients that present a certain manifestation within a stage of the disease, or the proportion of patients that receive a certain intervention within a strategy.</rdfs:comment>
        <rdfs:label xml:lang="en">has proportion within group</rdfs:label>
        <rdfs:label xml:lang="es">tiene la proporción dentro del grupo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isRiskCharacterizationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines the risk characterization of a clinical progression element, which can be expressed as a parameter (e.g., relative risk) or as a pathway (e.g., a pathway that defines the events that lead to the occurrence of a certain manifestation).</rdfs:comment>
        <rdfs:label xml:lang="en">has risk characterization</rdfs:label>
        <rdfs:label xml:lang="es">tiene la caracterización de riesgo</rdfs:label>
        <TODO>Check if this is the best name for the property</TODO>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSensitivity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSensitivity">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment>The Sensitivity in epidemiology is the Probability of correctly classifying a sick individual, that is, the Probability that a positive result will be obtained in a diagnostic test for a sick subject. The Sensitivity is, therefore, the ability of the complementary test to detect the disease. Sensitivity is the percentage of true positives or the Probability that the test is positive if the disease is present; False negatives are sick subjects diagnosed as healthy.</rdfs:comment>
        <rdfs:label xml:lang="en">has sensitivity</rdfs:label>
        <rdfs:label xml:lang="es">tiene la sensibilidad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSex -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSex">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_Sex"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines the sex of the population, which can be used to define the characteristics of the disease and the interventions. The value is the proportion of female individuals in the population.</rdfs:comment>
        <rdfs:label xml:lang="en">has sex</rdfs:label>
        <rdfs:label xml:lang="es">tiene sexo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSpecificity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSpecificity">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment>The Specificity of a test is the Probability that a healthy subject will have a negative test result. Specificity is the percentage of true negatives or the Probability that the test will be negative if the disease is not present. False positives are healthy subjects diagnosed as sick.</rdfs:comment>
        <rdfs:label xml:lang="en">has specificity</rdfs:label>
        <rdfs:label xml:lang="es">tiene la especificidad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasStrategy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasStrategy">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isStrategyOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Group"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGroupItem"/>
                                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a health condition, intervention or strategy and a strategy, which can be either a simple strategy or a group of strategies. This property allows us to define the strategies that are applied to a health condition, intervention or strategy, as well as the strategies that are part of a group of strategies.</rdfs:comment>
        <rdfs:label xml:lang="en">has strategy</rdfs:label>
        <rdfs:label xml:lang="es">tiene la estrategia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSubProgression -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSubProgression">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a clinical progression element and its sub-element, indicating that the sub-element only appear as a part of the clinical progression.</rdfs:comment>
        <rdfs:label xml:lang="en">has sub-progression</rdfs:label>
        <rdfs:label xml:lang="es">has sub-progression</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSubpopulation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSubpopulation">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isSubpopulationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a population and a subpopulation, indicating that the subpopulation is a subset of the population.</rdfs:comment>
        <rdfs:label xml:lang="en">has subpopulation</rdfs:label>
        <rdfs:label xml:lang="es">tiene la subpoblación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasTemporaryThreshold -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasTemporaryThreshold">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningStrategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment>Time limit in which the sample must be made. For example on the third day of birth. This value must be expressed in number of days.</rdfs:comment>
        <rdfs:label xml:lang="en">has temporary threshold</rdfs:label>
        <rdfs:label xml:lang="es">tiene el umbral temporal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isUncertaintyCharacterizationOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines the uncertainty characterization of a parameter, which can be expressed as another parameter (e.g., confidence interval) or as a probability distribution expression.</rdfs:comment>
        <rdfs:label xml:lang="en">has uncertainty characterization</rdfs:label>
        <rdfs:label xml:lang="es">tiene la caracterización de incertidumbre</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasUtility -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasUtility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
        <rdfs:comment xml:lang="en">Defines the utility associated with a health condition, intervention, pathway, population or resource usage item. The utility is a measure of the preference or value that individuals or society assign to a particular health state or outcome. It is often used in health economics and decision analysis to evaluate the desirability of different health outcomes and to inform healthcare decision-making.</rdfs:comment>
        <rdfs:label xml:lang="en">has utility</rdfs:label>
        <rdfs:label xml:lang="es">tiene la utilidad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#includedByModel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#includedByModel">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#includesModelItem"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a model item and a model, indicating that the model item is included as part of the structure or content of the model.</rdfs:comment>
        <rdfs:label xml:lang="en">included by model</rdfs:label>
        <rdfs:label xml:lang="es">incluido por el modelo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#includesModelItem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#includesModelItem">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a model and a model item, indicating that the model includes that item as part of its structure or content.</rdfs:comment>
        <rdfs:label xml:lang="en">includes model item</rdfs:label>
        <rdfs:label xml:lang="es">incluye el elemento del modelo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isAffectedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isAffectedBy">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
        <rdfs:comment xml:lang="en">Defines a relationship between an attribute or parameter and an effect, indicating that the attribute or parameter is affected by that effect.</rdfs:comment>
        <rdfs:label xml:lang="es">es modificado por</rdfs:label>
        <rdfs:label xml:lang="en">is modified by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isConditionExpressionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isConditionExpressionOf">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a condition expression and a guideline or strategy, indicating that the condition expression is used within the guideline or strategy.</rdfs:comment>
        <rdfs:label xml:lang="es">es expresión de condición de</rdfs:label>
        <rdfs:label xml:lang="en">is condition expression of</rdfs:label>
    </owl:ObjectProperty>
    


