                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between an effect and a health condition, intervention, pathway, population or resource usage item, indicating that the effect is associated with that element.</rdfs:comment>
