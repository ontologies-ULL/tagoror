        <rdfs:label xml:lang="es">es lenguaje de expresión de</rdfs:label>
        <rdfs:label xml:lang="en">is expression language of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isGuidelineOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isGuidelineOf">
