        <rdfs:label xml:lang="en">is guideline of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isInterventionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isInterventionOf">
