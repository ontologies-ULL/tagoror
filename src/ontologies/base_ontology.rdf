        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between an uncertainty characterization and a parameter or probability distribution expression, indicating that the characterization applies to that element.</rdfs:comment>
        <rdfs:label xml:lang="es">es caracterización de incertidumbre de</rdfs:label>
        <rdfs:label xml:lang="en">is uncertainty characterization of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isUsedAsAttributeValueBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isUsedAsAttributeValueBy">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between an attribute value parameter and a disease or population, indicating that the parameter is used as an attribute value for that disease or population.</rdfs:comment>
        <rdfs:label xml:lang="es">es utilizado como valor de atributo por</rdfs:label>
        <rdfs:label xml:lang="en">is used as attribute value by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isUsedByStrategy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isUsedByStrategy">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a health technology and a strategy, indicating that the health technology is used in that strategy.</rdfs:comment>
        <rdfs:label xml:lang="es">es utilizado por la estrategia</rdfs:label>
        <rdfs:label xml:lang="en">is used by strategy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a parameter and an attribute, indicating that the parameter is a value of that attribute.</rdfs:comment>
        <rdfs:label xml:lang="es">es valor del atributo</rdfs:label>
        <rdfs:label xml:lang="en">is value of attribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#requires -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#requires">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines that a pathway requires a certain clinical progression element or intervention. This can be useful for defining that a certain pathway requires the presence of a certain symptom or only appears when a certain intervention is applied.</rdfs:comment>
        <rdfs:label xml:lang="es">requiere</rdfs:label>
        <rdfs:label xml:lang="en">requires</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines that a clinical progression element replaces another one. This can be useful for defining that a certain manifestation replaces another one in the progression of the disease, for example, to define that a certain symptom appears after the disappearance of another symptom.</rdfs:comment>
        <rdfs:label xml:lang="es">reemplaza la progresión clínica</rdfs:label>
        <rdfs:label xml:lang="en">supersedes clinical progression</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a disease or population and a parameter which is the value of an attribute</rdfs:comment>
        <rdfs:label xml:lang="es">usa el valor del atributo</rdfs:label>
        <rdfs:label xml:lang="en">uses attribute value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a strategy and a health technology used in that strategy. This is useful for defining the health technologies used in a strategy, for example, to define that a certain drug is used in a treatment strategy or that a certain screening test is used in a screening strategy.</rdfs:comment>
        <rdfs:label xml:lang="en">uses health technology</rdfs:label>
        <rdfs:label xml:lang="es">utiliza tecnología sanitaria</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#usesModel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#usesModel">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">An experiment uses certain model</rdfs:comment>
        <rdfs:label xml:lang="es">usa el modelo</rdfs:label>
        <rdfs:label xml:lang="en">uses model</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#usesSameModelItemsAs -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#usesSameModelItemsAs">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">Defines that a model uses the same data items as another model. Useful for avoiding &quot;recreating&quot; that relationship for all the model items in models which are very similar and simply difer in some characteristics.</rdfs:comment>
        <rdfs:label xml:lang="en">uses same model items as</rdfs:label>
        <rdfs:label xml:lang="es">utiliza los mismos elementos del modelo que</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/ontologies-ULL/OSDi#appliesOneTime -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#appliesOneTime">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Defines the temporal behavior of a parameter (generally a cost or utility): if true, applies upon onset of some model item (disease, disease progression...); otherwise, it is assumed to apply annually.</rdfs:comment>
        <rdfs:label xml:lang="en">applies one time</rdfs:label>
        <rdfs:label xml:lang="es">se aplica una única vez</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasAlfaParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasAlfaParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#BetaDistributionExpression"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#GammaDistributionExpression"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the alpha parameter of a probability distribution, which is the shape parameter that determines the skewness of the distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has alfa parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro alfa</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasAuthor -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasAuthor">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Defines the author of a model. This can be useful for defining the author of a model, for example, to give credit to the creator of the model or to provide contact information for questions about the model.</rdfs:comment>
        <rdfs:label xml:lang="en">has author</rdfs:label>
        <rdfs:label xml:lang="es">tiene el autor</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasAverageParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasAverageParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the average parameter of a probability distribution, which is the mean of the distribution. This is useful for probability distributions which are defined by their mean and another parameter, such as the normal distribution (defined by its mean and standard deviation) or the Poisson distribution (defined by its mean, which is also its lambda parameter).</rdfs:comment>
        <rdfs:label xml:lang="en">has average parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro promedio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasBetaParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasBetaParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#BetaDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the beta parameter of a beta distribution, which is the shape parameter that determines the skewness of the distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has beta parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro beta</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasCalculationMethod -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasCalculationMethod">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#QoLDataItemType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Defines the method used to calculate a quality of life data item, for example, a utility or disutility. This can be useful for defining the method used to calculate a utility or disutility from a questionnaire, for example.</rdfs:comment>
        <rdfs:label xml:lang="en">has calculation method</rdfs:label>
        <rdfs:label xml:lang="es">tiene el método de cálculo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDescription">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the model item</rdfs:comment>
        <rdfs:label xml:lang="en">has description</rdfs:label>
        <rdfs:label xml:lang="es">tiene la descripción</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDiscountForCosts -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDiscountForCosts">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the discount rate for costs in the experiment.</rdfs:comment>
        <rdfs:label xml:lang="en">has discount for costs</rdfs:label>
        <rdfs:label xml:lang="es">tiene el descuento para costos</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDiscountForEffects -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDiscountForEffects">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the discount rate for effects in the experiment.</rdfs:comment>
        <rdfs:label xml:lang="en">has discount for effects</rdfs:label>
        <rdfs:label xml:lang="es">tiene el descuento para efectos</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasDisutilityCombinationMethod -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasDisutilityCombinationMethod">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>ADD</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>MAX</rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines the method used to combine disutilities in the experiment. This is useful for calculating the combined disutility of multiple health conditions or interventions in a population. The most common methods are ADD (which assumes that the disutilities are additive) and MAX (which assumes that the disutility of the combination is equal to the maximum disutility among the combined conditions or interventions).</rdfs:comment>
        <rdfs:label xml:lang="en">has disutility combination method</rdfs:label>
        <rdfs:label xml:lang="es">tiene el método de combinación de disutilidades</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">The expected value of a parameter with uncertainty. This is useful for deterministic parameters with uncertainty, which can be used in deterministic sensitivity analysis, and for second-order uncertainty parameters, which are used in two-level PSA.</rdfs:comment>
        <rdfs:label xml:lang="en">has expected value</rdfs:label>
        <rdfs:label xml:lang="es">tiene el valor esperado</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasExpressionValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasExpressionValue">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The expression in a formal language to calculate the value of a calculated parameter. The expression must be written using the syntax of the expression language defined for that parameter (see property isExpressionLanguageOf).</rdfs:comment>
        <rdfs:label xml:lang="en">has expression value</rdfs:label>
        <rdfs:label xml:lang="es">tiene el valor de expresión</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Model"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Defines the geographical context of a model, parameter or population. This can be useful for defining the scope of applicability of a model or parameter, for example.</rdfs:comment>
        <rdfs:label xml:lang="en">has geographical context</rdfs:label>
        <rdfs:label xml:lang="es">tiene el contexto geográfico</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasHoursInterval -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasHoursInterval">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Interval in which the indicated dose of drug should be given.</rdfs:comment>
        <rdfs:label xml:lang="en">has hours interval</rdfs:label>
        <rdfs:label xml:lang="es">tiene el intervalo de horas</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ExponentialDistributionExpression"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#GammaDistributionExpression"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#PoissonDistributionExpression"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the lambda parameter of a probability distribution, which is the rate parameter in an exponential distribution, the shape parameter in a gamma distribution and the average number of events in a Poisson distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has lambda parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro lambda</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasLowerLimitParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasLowerLimitParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#UniformDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the lower limit parameter of a uniform distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has lower limit parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de límite inferior</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasMaxAge -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasMaxAge">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the maximum age of a population</rdfs:comment>
        <rdfs:label xml:lang="en">has maximum age</rdfs:label>
        <rdfs:label xml:lang="es">tiene la edad máxima</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasMinAge -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasMinAge">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the minimum age of a population</rdfs:comment>
        <rdfs:label xml:lang="en">has minimum age</rdfs:label>
        <rdfs:label xml:lang="es">tiene la edad mínima</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasNullProgression -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasNullProgression">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#AlternativeCombinationRule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates that an alternative rule combination defines an option for &quot;none of the above&quot;</rdfs:comment>
        <rdfs:label xml:lang="en">has null progression</rdfs:label>
        <rdfs:label xml:lang="es">tiene progresión nula</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasNumberOfPSARuns -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasNumberOfPSARuns">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Defines the number of runs for the probabilistic sensitivity analysis (PSA) in the experiment</rdfs:comment>
        <rdfs:label xml:lang="en">has number of PSA runs</rdfs:label>
        <rdfs:label xml:lang="es">tiene número de ejecuciones de PSA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasNumberOfSimulatedIndividuals -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasNumberOfSimulatedIndividuals">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Defines the number of simulated individuals in the experiment</rdfs:comment>
        <rdfs:label xml:lang="en">has number of simulated individuals</rdfs:label>
        <rdfs:label xml:lang="es">tiene número de individuos simulados</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasOffsetParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasOffsetParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the offset parameter of a probability distribution, which is a value that is added to the random variable defined by the distribution. This is useful for defining distributions that can only take values above or below a certain threshold (for example, an offset of 1 in a Poisson distribution would define a distribution that can only take values from 1 to infinite, instead of from 0 to infinite).</rdfs:comment>
        <rdfs:label xml:lang="en">has offset parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de desplazamiento</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines a parameter of a probability distribution. This is a general property which can be used for any parameter of any probability distribution, but more specific subproperties are provided for the most common parameters (average, variance, lambda, etc.)</rdfs:comment>
        <rdfs:label xml:lang="en">has probability distribution parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de distribución de probabilidad</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasProbabilityParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#BernoulliDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the probability parameter of a Bernoulli distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has probability parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de probabilidad</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRange -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRange">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Age range in which the drug will be delivered.

Examples: 
   0y-2y    =&gt; 0 years to 2 years
   3m-2y   =&gt; 3 months to 2 years</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefTo -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Model"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in an external ontology or database, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToDO -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToDO">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in DO, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to DO</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a DO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToGARD -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToGARD">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#RareDisease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in GARD, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to GARD</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a GARD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToICD -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToICD">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in ICD, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to ICD</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a ICD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToOMIM -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToOMIM">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in OMIM, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to OMIM</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a OMIM</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToORDO -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToORDO">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#RareDisease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in ORDO, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to ORDO</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a ORDO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToSNOMED -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToSNOMED">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in SNOMED CT, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to SNOMED</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a SNOMED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in STATO, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to STATO</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a STATO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasRefToWikidata -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasRefToWikidata">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Currency"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference to the corresponding item in Wikidata, if available</rdfs:comment>
        <rdfs:label xml:lang="en">has reference to Wikidata</rdfs:label>
        <rdfs:label xml:lang="es">tiene la referencia a Wikidata</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasScaleParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasScaleParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the scale parameter of a probability distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has scale parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de escala</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSize -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSize">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of individuals in the population</rdfs:comment>
        <rdfs:label xml:lang="en">has size</rdfs:label>
        <rdfs:label xml:lang="es">tiene el tamaño</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasSource -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasSource">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Source of the parameter value, e.g., a bibliographic reference, name of a dataset, name of an expert...</rdfs:comment>
        <rdfs:label xml:lang="en">has source</rdfs:label>
        <rdfs:label xml:lang="es">tiene la fuente</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasStandardDeviationParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasStandardDeviationParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the standard deviation parameter of a probability distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has standard deviation parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de desviación estándar</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasTimeHorizon -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasTimeHorizon">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the time horizon (in years) applied to a simulation</rdfs:comment>
        <rdfs:label xml:lang="en">has time horizon</rdfs:label>
        <rdfs:label xml:lang="es">tiene horizonte temporal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasUnit -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasUnit">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#MeasuredDataItemType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unit of measurement of a data item type, e.g., &quot;years&quot;, &quot;kg&quot;, &quot;number of cases&quot;...</rdfs:comment>
        <rdfs:label xml:lang="en">has unit</rdfs:label>
        <rdfs:label xml:lang="es">tiene la unidad</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasUpperLimitParameter -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasUpperLimitParameter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityDistributionParameter"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#UniformDistributionExpression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Defines the upper limit parameter of a uniform distribution</rdfs:comment>
        <rdfs:label xml:lang="en">has upper limit parameter</rdfs:label>
        <rdfs:label xml:lang="es">tiene el parámetro de límite superior</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#hasYear -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#hasYear">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Experiment"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#short"/>
        <rdfs:comment>Year in which the cost data is collected</rdfs:comment>
        <rdfs:label xml:lang="en">has year</rdfs:label>
        <rdfs:label xml:lang="es">tiene el año</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isAssessedIntervention -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isAssessedIntervention">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether an intervention is being assessed or it is a comparator</rdfs:comment>
        <rdfs:label xml:lang="es">es una intervención evaluada</rdfs:label>
        <rdfs:label xml:lang="en">is assessed intervention</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isDisutility -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isDisutility">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a utility parameter represents a disutility or a utility</rdfs:comment>
        <rdfs:label xml:lang="es">es una desutilidad</rdfs:label>
        <rdfs:label xml:lang="en">is disutility</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isTrueEpidemiologicalParameterEstimate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isTrueEpidemiologicalParameterEstimate">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether an epidemiological parameter is a true estimate of the parameter or an estimation with known biases</rdfs:comment>
        <rdfs:label xml:lang="es">es una estimación verdadera de un parámetro epidemiológico</rdfs:label>
        <rdfs:label xml:lang="en">is true epidemiological parameter estimate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Manifestation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasFrequency"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionWithInitialProportion"/>
        <rdfs:comment xml:lang="en">Sudden or rapid appearance of clinical signs or symtoms, in general with a short and intense course</rdfs:comment>
        <rdfs:label xml:lang="en">Acute manifestation</rdfs:label>
        <rdfs:label xml:lang="es">Manifestación aguda</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#AgentBasedModel -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#AgentBasedModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">An model based on using multiple agents</rdfs:comment>
        <rdfs:label xml:lang="en">Agent based model</rdfs:label>
        <rdfs:label xml:lang="es">Modelo basado en agentes</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#AlternativeCombinationRule -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#AlternativeCombinationRule">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasNullProgression"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of disease progressions which are treated as mutually exclusive alternatives, e.g., a mild and a severe development of certain disease</rdfs:comment>
        <rdfs:label xml:lang="en">Alternative disease progression set</rdfs:label>
        <rdfs:label xml:lang="es">Conjunto de progresiones de enfermedad alternativas</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Attribute -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAttributeValue"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isAffectedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSNOMED"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemDefiningDiseaseProgression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithCost"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithDetection"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithEffect"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithFollowUp"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithRiskCharacterization"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTemporalConstraints"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTreatment"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithUtility"/>
        <rdfs:comment xml:lang="en">Clinical parameters that define the state of a patient and whose value may modify the evolution of the Disease and/or specific manifestations</rdfs:comment>
        <rdfs:label xml:lang="es">Atributo</rdfs:label>
        <rdfs:label xml:lang="en">Attribute</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#AttributeValueParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">A parameter that represents the value of an attribute</rdfs:comment>
        <rdfs:label xml:lang="en">Attribute Value Parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro de valor de atributo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#BernoulliDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#BernoulliDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000262</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProbabilityParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A discrete (0-1) probability distribution with just one parameter (the probability of an event)</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad de Bernoulli</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Bernoulli probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#BetaDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#BetaDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000177</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAlfaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasBetaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Continuous probability distributions defined on the interval [0, 1] parametrized by two positive shape parameters, alfa and beta, generally estimated from the number of &apos;cases&apos; and &apos;no cases&apos; from an event</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad Beta</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Beta probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#dependsOn"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasExpressionLanguage"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasExpressionValue"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ParameterNature"/>
        <rdfs:comment xml:lang="en">Parameter which value is computed using an expression, generally dependent on other parameters</rdfs:comment>
        <rdfs:label xml:lang="en">Calculated Parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro calculado</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Manifestation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Long-lasting or frequently recurring set of signs and symptoms</rdfs:comment>
        <rdfs:label xml:lang="en">Chronic manifestation</rdfs:label>
        <rdfs:label xml:lang="es">Manifestación crónica</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDuration"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEndAge"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasOnsetAge"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSubProgression"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToICD"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Any way in which a disease can progress: manifestations, symptoms, stages...</rdfs:comment>
        <rdfs:label xml:lang="en">Disease progression</rdfs:label>
        <rdfs:label xml:lang="es">Progresión de una enfermedad</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionWithInitialProportion -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionWithInitialProportion">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">A clinical progression element that is present in an initial proportion in a population</rdfs:comment>
        <rdfs:label xml:lang="en">Clinical progression with initial proportion</rdfs:label>
        <rdfs:label xml:lang="es">Progresión clínica con proporción inicial</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#CoexistentCombinationRule -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#CoexistentCombinationRule">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
        <rdfs:comment>A set of disease progressions which can coexist at the same time, e.g. seizures and skin problems.</rdfs:comment>
        <rdfs:label xml:lang="en">Coexistent disease progression set</rdfs:label>
        <rdfs:label xml:lang="es">Conjunto de progresiones de enfermedad coexistentes</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Cost -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Cost">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#YearDependantParameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Currency"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#YearDependantParameter"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#appliesOneTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The cost of any component of the model (intervention, treatment, disease progression...)</rdfs:comment>
        <rdfs:label xml:lang="en">Cost</rdfs:label>
        <rdfs:label xml:lang="es">Coste</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Currency -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Currency">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#MeasuredDataItemType"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToWikidata"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Data type to express costs</rdfs:comment>
        <rdfs:label xml:lang="en">Currency</rdfs:label>
        <rdfs:label xml:lang="es">Moneda</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DataItemType -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DataItemType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The type to define the nature of a data item, either its statistic nature (probability, relative risk...) or some characteristic (currency, utility...)</rdfs:comment>
        <rdfs:label xml:lang="en">Data item type</rdfs:label>
        <rdfs:label xml:lang="es">Tipo del elemento de datos</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DecisionTreeModel -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DecisionTreeModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">A model based on a decision tree</rdfs:comment>
        <rdfs:label xml:lang="en">Decision tree model</rdfs:label>
        <rdfs:label xml:lang="es">Modelo de árbol de decisión</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Describable -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Describable">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDescription"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Any concept that can be described with a text</rdfs:comment>
        <rdfs:label xml:lang="en">Describable</rdfs:label>
        <rdfs:label xml:lang="es">Describible</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiagnosisIntervention"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#detects"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSensitivity"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DI_Sensitivity"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSpecificity"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DI_Specificity"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiagnosisIntervention"/>
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">An intervention intended to detect the presence of a disease or condition in a person</rdfs:comment>
        <rdfs:label xml:lang="en">Detection intervention</rdfs:label>
        <rdfs:label xml:lang="es">Intervención de detección</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#detects"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSensitivity"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DI_Sensitivity"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSpecificity"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                                <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DI_Specificity"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">A strategy related to the detection of a disease</rdfs:comment>
        <rdfs:label xml:lang="en">Detection strategy</rdfs:label>
        <rdfs:label xml:lang="es">Estrategia de detección</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxQualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ParameterNature"/>
        <rdfs:comment xml:lang="en">Parameter with a fixed (no-uncertainty) value</rdfs:comment>
        <rdfs:label xml:lang="en">Deterministic parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro determinista</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Development -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Development">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Certain progression of a Disease that comprises a specific set of manifestations or a set of pathways to such manifestations</rdfs:comment>
        <rdfs:label xml:lang="es">Desarrollo</rdfs:label>
        <rdfs:label xml:lang="en">Development</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DiagnosisIntervention -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiagnosisIntervention">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiagnosisCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention"/>
        <rdfs:comment xml:lang="en">An intervention intended to establish the presence/absence of certain disease or condition</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnosis intervention</rdfs:label>
        <rdfs:label xml:lang="es">Intervención diagnóstica</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DiagnosisStrategy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiagnosisStrategy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiagnosisCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
        <rdfs:comment xml:lang="es">A strategy related to the diagnosis of a disease</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnosis strategy</rdfs:label>
        <rdfs:label xml:lang="es">Estrategia de diagnóstico</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DiscreteEventSimulationModel -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiscreteEventSimulationModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">A model based on discrete events and entities</rdfs:comment>
        <rdfs:label xml:lang="en">Discrete-event simulation model</rdfs:label>
        <rdfs:label xml:lang="es">Modelo de simulación de eventos discretos</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Disease -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Disease">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#HealthCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasIntervention"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToDO"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToICD"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToOMIM"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSNOMED"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Any type of disease or health condition that a person may suffer. Since diseases may have or not costs, utilities... all of these properties has been explicitly defined with cardinality &apos;min 0&apos; as an hint for the ontology users</rdfs:comment>
        <rdfs:label xml:lang="en">Disease</rdfs:label>
        <rdfs:label xml:lang="es">Enfermedad</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:comment xml:lang="en">An element characterizing the progression of a disease</rdfs:comment>
        <rdfs:label xml:lang="en">Disease progression element</rdfs:label>
        <rdfs:label xml:lang="es">Elemento de progresión de la enfermedad</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Effect -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Effect">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#affects"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffectMagnitude"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An effect of a treatment or intervention</rdfs:comment>
        <rdfs:label xml:lang="es">Efecto</rdfs:label>
        <rdfs:label xml:lang="en">Effect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isTrueEpidemiologicalParameterEstimate"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">A parameter related to the epidemiology (prevalence, incidence...) of a disease or condition</rdfs:comment>
        <rdfs:label xml:lang="en">Epidemiological parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro epidemiológico</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Experiment -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Experiment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesModel"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDisutilityCombinationMethod"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange>
                    <rdfs:Datatype>
                        <owl:oneOf>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>ADD</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>MAX</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </owl:oneOf>
                    </rdfs:Datatype>
                </owl:onDataRange>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasYear"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#short"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDiscountForCosts"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDiscountForEffects"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasTimeHorizon"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An HTA experiment that uses a model, some input parameters and obtains results</rdfs:comment>
        <rdfs:label xml:lang="en">Experiment</rdfs:label>
        <rdfs:label xml:lang="es">Experimento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ExponentialDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ExponentialDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000160</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Continuous probability distribution that describes the time between events in a Poisson process, i.e. a process in which events occur continuously and independently at a constant average rate</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad Exponencial</rdfs:label>
        <rdfs:label xml:lang="en">Expression for an Expnential probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Exp_Excel"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Exp_JEXL"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Exp_Java"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Exp_Javaluator"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:comment xml:lang="en">Language used to define an expression in a string. Generally used to compute something from other items of the model. Only the predefined languages are allowed, but future versions of the ontology may include more.</rdfs:comment>
        <rdfs:label xml:lang="en">Expression language</rdfs:label>
        <rdfs:label xml:lang="es">Lenguaje de expresión</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxQualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ParameterNature"/>
        <rdfs:comment xml:lang="en">Parameter which value has first-order uncertainty, i.e., the value for each individual is not fixed</rdfs:comment>
        <rdfs:label xml:lang="en">First-order uncertainty parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro con incertidumbre de primer orden</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#FollowUpCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:comment xml:lang="es">A strategy related to the follow-up of a disease or condition</rdfs:comment>
        <rdfs:label xml:lang="es">Estrategia de seguimiento</rdfs:label>
        <rdfs:label xml:lang="en">Follow-up strategy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#GammaDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#GammaDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000268</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAlfaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Continuous distribution of probability generally used to model costs, characterized by two parameters: alpha (shape) and lamba (scale)</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad Gamma</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Gamma probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Group -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Group">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGroupItem"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:comment xml:lang="en">A group of model items. Useful to categorize or &apos;putting together&apos; manifestations (e.g. all the eye-related manifestations of diabetes) or other model items</rdfs:comment>
        <rdfs:label xml:lang="en">Group</rdfs:label>
        <rdfs:label xml:lang="es">Grupo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#belongsToGroup"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Group"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:comment xml:lang="en">A model item that can be put in a group</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo agrupable</rdfs:label>
        <rdfs:label xml:lang="en">Groupable model item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#GroupableModelItemWithProportion -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItemWithProportion">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProportionWithinGroup"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#GroupableModelItem"/>
        <rdfs:comment xml:lang="en">A model item that can be put in a group</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo agrupable</rdfs:label>
        <rdfs:label xml:lang="en">Groupable model item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Guideline -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Guideline">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGuideline"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasConditionExpression"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDose"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasFrequency"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRange"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasHoursInterval"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithCost"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithUtility"/>
        <rdfs:comment>The way a treatment, drug, test... is applied. It defines a period of time (range), dose, frequency, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Guideline</rdfs:label>
        <rdfs:label xml:lang="es">Pauta</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#HealthCondition -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthCondition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffect"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Any disease, symptom or clinical sign that affects the health of an individual</rdfs:comment>
        <rdfs:label xml:lang="es">Condición de salud</rdfs:label>
        <rdfs:label xml:lang="en">Health condition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#HealthTechnology -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:comment xml:lang="en">Any treatment, drug, test... that may be applied to a patient. In the context of this ontology, this class and its subclasses define resource usage to compute costs and must not be confused with the &apos;interventions&apos;</rdfs:comment>
        <rdfs:label xml:lang="en">Health technology</rdfs:label>
        <rdfs:label xml:lang="es">Tecnología sanitaria</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#IncreasedMortalityRateEffect -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#IncreasedMortalityRateEffect">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#affects"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_LifeExpectancy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An increment on the mortality rate of an individual or population.</rdfs:comment>
        <rdfs:label xml:lang="es">Efecto de incremento en la tasa de mortalidad</rdfs:label>
        <rdfs:label xml:lang="en">Incresed of mortality rate effect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#InfectiousDisease -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#InfectiousDisease">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#InheritedDisease"/>
        <rdfs:comment xml:lang="en">A disease that is transmitted from one person to another through various means</rdfs:comment>
        <rdfs:label xml:lang="es">Enfermedad infecciosa</rdfs:label>
        <rdfs:label xml:lang="en">Infectious disease</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#InheritedDisease -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#InheritedDisease">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:comment xml:lang="en">A disease that is passed down from parent to child through genes</rdfs:comment>
        <rdfs:label xml:lang="es">Enfermedad hereditaria</rdfs:label>
        <rdfs:label xml:lang="en">Inherited disease</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#InstantDeathEffect -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#InstantDeathEffect">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#affects"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_LifeExpectancy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Defines an &apos;instantaneous&apos; death risk, e.g., a probability of dying upon the onset of a condition</rdfs:comment>
        <rdfs:label xml:lang="es">Efecto de muerte instantánea</rdfs:label>
        <rdfs:label xml:lang="en">Instantaneous death effect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Intervention -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isAssessedIntervention"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffect"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemDefiningDiseaseProgression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithRiskCharacterization"/>
        <rdfs:comment xml:lang="en">Some kind of treatment, drug, surgical procedure... used to modify the development of a Disease. In the context of this ontology, interventions are the comparing options in the decision-making process</rdfs:comment>
        <rdfs:label xml:lang="es">Intervención</rdfs:label>
        <rdfs:label xml:lang="en">Intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#LifeExpectancyReductionEffect -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#LifeExpectancyReductionEffect">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#affects"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_LifeExpectancy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An effect that reduces the life expectancy of an individual or population.</rdfs:comment>
        <rdfs:label xml:lang="es">Efecto de reducción en la esperanza de vida</rdfs:label>
        <rdfs:label xml:lang="en">Life expectancy reduction effect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#TreatmentCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#failsIf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">A strategy related to the treatment of a disease or condition</rdfs:comment>
        <rdfs:label xml:lang="es">Estrategia de tratamiento</rdfs:label>
        <rdfs:label xml:lang="en">Line-of-therapy strategy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Manifestation -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Manifestation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSubProgression"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#AcuteManifestation"/>
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ChronicManifestation"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">Symptoms or signs of a disease. They may be chronic or acute</rdfs:comment>
        <rdfs:label xml:lang="es">Manifestación</rdfs:label>
        <rdfs:label xml:lang="en">Manifestation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#MarkovModel -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#MarkovModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
        <rdfs:comment xml:lang="en">Model based on Markov states and transitions</rdfs:comment>
        <rdfs:label xml:lang="en">Markov model</rdfs:label>
        <rdfs:label xml:lang="es">Modelo de Markov</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#MeasuredDataItemType -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#MeasuredDataItemType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUnit"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
        <rdfs:comment xml:lang="en">Type for datas items that are measureable</rdfs:comment>
        <rdfs:label xml:lang="en">Measured data item type</rdfs:label>
        <rdfs:label xml:lang="es">Tipo del elemento de datos medible</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Model -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Model">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#includesModelItem"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesSameModelItemsAs"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAuthor"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefTo"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A container to define all the items that conform a model that can be simulated</rdfs:comment>
        <rdfs:label xml:lang="en">Model</rdfs:label>
        <rdfs:label xml:lang="es">Modelo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItem -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#includedByModel"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Model"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Describable"/>
        <rdfs:comment xml:lang="en">Any component of a model</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo</rdfs:label>
        <rdfs:label xml:lang="en">Model item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemDefiningDiseaseProgression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemDefiningDiseaseProgression">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:comment xml:lang="en">A model item that defines the progression of a disease</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo definiendo progreso de la enfermedad</rdfs:label>
        <rdfs:label xml:lang="en">Model item defining disease progression</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithCost -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithCost">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:comment xml:lang="en">A model item that has at least one associated cost, i.e., it must be taken into account when computing the cost of the cost-effectiveness analysis</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con coste</rdfs:label>
        <rdfs:label xml:lang="en">Model item with cost</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithDetection -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithDetection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#TherapeuticIntervention"/>
        <rdfs:comment xml:lang="en">A model item that represents a detection mechanism for a disease</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con detección</rdfs:label>
        <rdfs:label xml:lang="en">Model item with detection</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithEffect -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithEffect">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffect"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:comment xml:lang="en">A model item that has at least one associated effect</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con efecto</rdfs:label>
        <rdfs:label xml:lang="en">Model item with effect</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithFollowUp -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithFollowUp">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                        <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:comment xml:lang="en">A model item that has at least one associated follow-up cost or strategy</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con seguimiento</rdfs:label>
        <rdfs:label xml:lang="en">Model item with follow-up</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithRiskCharacterization -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithRiskCharacterization">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRiskCharacterization"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:comment xml:lang="en">A model item that has risk characterization, i.e., associated with a parameter or pathway that represents a risk factor</rdfs:comment>
        <rdfs:label xml:lang="en">Model item with risk characterization</rdfs:label>
        <rdfs:label xml:lang="es">Tipo de elemento del modelo con caracterización de riesgo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTemporalConstraints -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTemporalConstraints">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDuration"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEndAge"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasOnsetAge"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:comment xml:lang="en">A model item that has temporal constraints, i.e., duration, onset age, and end age</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con restricciones temporales</rdfs:label>
        <rdfs:label xml:lang="en">Model item with temporal constraints</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTreatment -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithTreatment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                        <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:comment xml:lang="en">A model item that has at least one associated treatment cost or line-of-therapy</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con tratamiento</rdfs:label>
        <rdfs:label xml:lang="en">Model item with treatment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ModelItemWithUtility -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItemWithUtility">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <owl:disjointWith rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:comment xml:lang="en">A model item that has at least one associated utility, i.e., it must be taken into account when computing the effectiveness of the cost-effectiveness analysis</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo con utilidad</rdfs:label>
        <rdfs:label xml:lang="en">Model item with utility</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#NormalDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#NormalDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000227</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Unbounded and symmetric continuous probability distribution, characterized by two parameters: average, that falls in the mode of the distribution, and standard deviation.</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad Normal</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Normal probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasNext"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasPrevious"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:comment xml:lang="en">A model item that has a specific order with respect to other model items, such as the stage of a disease</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento del modelo ordenado</rdfs:label>
        <rdfs:label xml:lang="en">Ordered Model Item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Parameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isAffectedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSource"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Parameters used for computing outcomes or characterize certain class. They have a source, a geographical context, year, description and value</rdfs:comment>
        <rdfs:label xml:lang="en">Parameter</rdfs:label>
        <rdfs:label xml:lang="es">Parámetro</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ParameterNature -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ParameterNature">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DeterministicParameter"/>
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FirstOrderUncertaintyParameter"/>
            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">The nature of the values of a parameter, i.e., whether it is a constant, calculated, or characterizes uncertainty somehow. This must be used to define parameters together with &apos;Parameter&apos; or any of its subclasses, i.e. an individual defining the cost of a drug should be subclass of both &apos;Cost&apos; and &apos;DeterministicParameter&apos;</rdfs:comment>
        <rdfs:label xml:lang="es">Naturaleza del parámetro</rdfs:label>
        <rdfs:label xml:lang="en">Parameter nature</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Pathway -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffect"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#requires"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The way a disease, development, manifestation or stage appears, i.e., the conditions that must be met to lead to any of these.</rdfs:comment>
        <rdfs:label xml:lang="en">Pathway</rdfs:label>
        <rdfs:label xml:lang="es">Ruta</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#PoissonDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#PoissonDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:hasValue>http://purl.obolibrary.org/obo/STATO_0000051</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasLambdaParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Discrete probability distribution used to model the number of events occurring within a given time interval. It is defined by a real number (lambda).</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad de Poisson</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Poisson probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Population -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Population">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesAttributeValue"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEpidemiologicalParameter"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#EpidemiologicalParameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasParameter"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSubpopulation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAge"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_Age"/>
                    </owl:Restriction>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSex"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_Sex"/>
                    </owl:Restriction>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasLifeExpectancy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isValueOfAttribute"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Attribute_LifeExpectancy"/>
                    </owl:Restriction>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isSubpopulationOf"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGeographicalContext"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasMaxAge"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasMinAge"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSize"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasYear"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#short"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The characteristics of the population which is the objective of the assessed interventions</rdfs:comment>
        <rdfs:label xml:lang="es">Población</rdfs:label>
        <rdfs:label xml:lang="en">Population</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasAverageParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasOffsetParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToSTATO"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasScaleParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStandardDeviationParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An expression that defines a probablity distribution</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad</rdfs:label>
        <rdfs:label xml:lang="en">Probability distribution expression</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DiseaseProgressionElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#affectsProgressionElement"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A rule that defines how to combine a set of disease progressions (exclusions, coexistence...)</rdfs:comment>
        <rdfs:label xml:lang="en">Pogression combination rule</rdfs:label>
        <rdfs:label xml:lang="es">Regla de combinación de progresiones</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#QoLDataItemType -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#QoLDataItemType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DataItemType"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCalculationMethod"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A type of data item related to quality-of-life measures</rdfs:comment>
        <rdfs:label xml:lang="en">Quality-of-Life Data Item Type</rdfs:label>
        <rdfs:label xml:lang="es">Tipo de elemento de datos de calidad de vida</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#RareDisease -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#RareDisease">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToGARD"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasRefToORDO"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A disease with very low  prevalence</rdfs:comment>
        <rdfs:label xml:lang="es">Enfermedad rara</rdfs:label>
        <rdfs:label xml:lang="en">Rare disease</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ModelItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCost"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Cost"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasEffect"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Effect"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGuideline"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Guideline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUtility"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Utility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Item related to the use of health resources, belonging to some specific category</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento de uso de recursos</rdfs:label>
        <rdfs:label xml:lang="en">Resource Usage Item</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningIntervention">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ScreeningCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DetectionIntervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasTemporaryThreshold"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An intervention to identifiy the subset of population who may have certain disease or condition and require further testing to obtain a final diagnosis</rdfs:comment>
        <rdfs:label xml:lang="es">Intervención de cribado</rdfs:label>
        <rdfs:label xml:lang="en">Screening intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#ScreeningStrategy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#ScreeningStrategy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ScreeningCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#DetectionStrategy"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasTemporaryThreshold"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A strategy related to the identification of persons potentially suffering a disease among a population</rdfs:comment>
        <rdfs:label xml:lang="es">Estrategia de cribado</rdfs:label>
        <rdfs:label xml:lang="en">Screening strategy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#SecondOrderUncertaintyParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUncertaintyCharacterization"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasExpectedValue"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ParameterNature"/>
        <rdfs:comment xml:lang="en">Parameter which value has second-order uncertainty, i.e. the precise value is not known and is subject to uncertainty. For example, the actual value of the effectiveness of a treatment could have been derived from a metaanalysis of several studies and being defined by an average but also confidence intervals</rdfs:comment>
        <rdfs:label xml:lang="es">Parámetro con incertidumbre de segundo orden</rdfs:label>
        <rdfs:label xml:lang="en">Second-order uncertainty parameter</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#SequentialCombinationRule -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#SequentialCombinationRule">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasProgressionElement"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#OrderedModelItem"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasFirst"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A set of disease progressions that appear sequentially, e.g., the stages of a cancer</rdfs:comment>
        <rdfs:label xml:lang="es">Conjunto de progresiones de enfermedad secuenciales</rdfs:label>
        <rdfs:label xml:lang="en">Sequential disease progression set</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Stage -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Stage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasInitialProportion"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isParameterOf"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasSubProgression"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                            <owl:Class>
                                <owl:complementOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Development"/>
                            </owl:Class>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A phase or step in the progression of a disease</rdfs:comment>
        <rdfs:label xml:lang="es">Estadio</rdfs:label>
        <rdfs:label xml:lang="en">Stage</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Strategy -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ResourceUsageItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#followedByStrategy"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasGroupItem"/>
                                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasConditionExpression"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#usesHealthTechnology"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/ontologies-ULL/OSDi#HealthTechnology"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">A way of defining a series of steps required to treat, detect or follow-up a disease or condition</rdfs:comment>
        <rdfs:label xml:lang="es">Estrategia</rdfs:label>
        <rdfs:label xml:lang="en">Strategy</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#TherapeuticIntervention -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#TherapeuticIntervention">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasCategory"/>
                        <owl:hasValue rdf:resource="https://w3id.org/ontologies-ULL/OSDi#TreatmentCat"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasStrategy"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#FollowUpStrategy"/>
                            <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#LineOfTherapy"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An intervention driven by a set of drugs and/or treatments</rdfs:comment>
        <rdfs:label xml:lang="es">Intervención terapéutica</rdfs:label>
        <rdfs:label xml:lang="en">Therapeutic intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#UniformDistributionExpression -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#UniformDistributionExpression">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ProbabilityDistributionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasLowerLimitParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasUpperLimitParameter"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A bounded continuous probability distribution, where the ocurrence of an event is equally probable inside the defined limits</rdfs:comment>
        <rdfs:label xml:lang="es">Expresión para distribución de probabilidad Uniforme</rdfs:label>
        <rdfs:label xml:lang="en">Expression for a Uniform probability distribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#Utility -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#Utility">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasDataItemType"/>
                                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                                <owl:onClass rdf:resource="https://w3id.org/ontologies-ULL/OSDi#QoLDataItemType"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#isDisutility"/>
                                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#appliesOneTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The self-perceived utility (or disutility) of a health state, used to compute quality-adjusted life years</rdfs:comment>
        <rdfs:label xml:lang="es">Utilidad</rdfs:label>
        <rdfs:label xml:lang="en">Utility</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#YearDependantParameter -->

    <owl:Class rdf:about="https://w3id.org/ontologies-ULL/OSDi#YearDependantParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/ontologies-ULL/OSDi#hasYear"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#short"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">A parameter which value that depends on the year, such as costs</rdfs:comment>
        <rdfs:label xml:lang="es">Parámetro dependiente del año</rdfs:label>
        <rdfs:label xml:lang="en">Year-Dependent Parameter</rdfs:label>
    </owl:Class>
    


