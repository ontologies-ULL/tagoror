        <rdfs:comment xml:lang="en">Defines a relationship between an intervention and a disease, indicating that the intervention is used to treat the disease.</rdfs:comment>
        <rdfs:label xml:lang="es">es intervención de</rdfs:label>
        <rdfs:label xml:lang="en">is intervention of</rdfs:label>
    </owl:ObjectProperty>
    


