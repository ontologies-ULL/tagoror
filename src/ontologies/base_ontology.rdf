    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isExpressionLanguageOf">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ExpressionLanguage"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#CalculatedParameter"/>
