                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ProgressionCombinationRule"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Defines a relationship between a disease progression element and a disease or progression combination rule.</rdfs:comment>
        <rdfs:label xml:lang="es">es elemento de progresión de</rdfs:label>
        <rdfs:label xml:lang="en">is progression element of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isRequiredBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isRequiredBy">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#requires"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Intervention"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a clinical progression element and a pathway, indicating that the element is required by the pathway.</rdfs:comment>
        <rdfs:label xml:lang="es">es requerido por</rdfs:label>
        <rdfs:label xml:lang="en">is required by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isRiskCharacterizationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isRiskCharacterizationOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
                    <rdf:Description rdf:about="https://w3id.org/ontologies-ULL/OSDi#Pathway"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a risk characterization and a clinical progression element, indicating that the characterization applies to that element.</rdfs:comment>
        <rdfs:label xml:lang="es">es caracterización de riesgo de</rdfs:label>
        <rdfs:label xml:lang="en">is risk characterization of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isStrategyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isStrategyOf">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Strategy"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a strategy and a pathway, indicating that the strategy is used in the pathway.</rdfs:comment>
        <rdfs:label xml:lang="es">es estrategia de</rdfs:label>
        <rdfs:label xml:lang="en">is strategy of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isSubpopulationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isSubpopulationOf">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Population"/>
        <rdfs:comment xml:lang="en">Defines a relationship between two populations, indicating that the domain population is a subpopulation of the range population.</rdfs:comment>
        <rdfs:label xml:lang="es">es subpoblación de</rdfs:label>
        <rdfs:label xml:lang="en">is subpopulation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isSupersededByClinicalProgression -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isSupersededByClinicalProgression">
        <owl:inverseOf rdf:resource="https://w3id.org/ontologies-ULL/OSDi#supersedesClinicalProgression"/>
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#ClinicalProgressionElement"/>
        <rdfs:comment xml:lang="en">Defines a relationship between two clinical progression elements, indicating that the domain element is superseded by the range element.</rdfs:comment>
        <rdfs:label xml:lang="es">es reemplazado por</rdfs:label>
        <rdfs:label xml:lang="en">is superseded by</rdfs:label>
    </owl:ObjectProperty>
    


