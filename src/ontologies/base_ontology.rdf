        <rdfs:range rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Parameter"/>
        <rdfs:comment xml:lang="en">Defines a relationship between a data item type and a parameter, indicating that the data item type is used to define the parameter.</rdfs:comment>
        <rdfs:label xml:lang="es">es tipo de elemento de datos de</rdfs:label>
        <rdfs:label xml:lang="en">is data item type of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ontologies-ULL/OSDi#isDetectedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/ontologies-ULL/OSDi#isDetectedBy">
        <rdfs:domain rdf:resource="https://w3id.org/ontologies-ULL/OSDi#Disease"/>
